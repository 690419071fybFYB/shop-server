{
  "name": "hioshop",
  "description": "hioshop - open source mini program shop",
  "version": "1.0.0",
  "scripts": {
    "start": "node development.js",
    "start:prod": "node production.js",
    "compile": "node scripts/compile.js",
    "compile:emit-app": "node scripts/compile.js --emit-app",
    "lint": "eslint \"src/**/*.js\" \"scripts/**/*.js\" development.js production.js bootstrap.js",
    "lint-fix": "eslint --fix \"src/**/*.js\" \"scripts/**/*.js\" development.js production.js bootstrap.js",
    "test:goods-import": "node scripts/test-goods-import.js",
    "test:coupon": "node scripts/test-coupon.js",
    "test:security-regression": "node scripts/test-security-regression.js",
    "test:auth-context-isolation": "node scripts/test-auth-context-isolation.js",
    "test:order-sn-regression": "node scripts/test-order-sn-regression.js",
    "test:pr-gate": "npm run compile && npm run lint && npm run test:coupon && npm run test:security-regression && npm run test:auth-context-isolation && npm run test:order-sn-regression",
    "test:promotion-v1": "node scripts/test-promotion-v1.js",
    "test:cos-smoke": "node scripts/test-cos-smoke.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1006.0",
    "@aws-sdk/s3-request-presigner": "^3.1006.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "jsonwebtoken": "^9.0.3",
    "kcors": "^2.2.2",
    "lodash": "^4.17.23",
    "md5": "^2.3.0",
    "mime-types": "^3.0.2",
    "moment": "^2.30.1",
    "mysql2": "^3.19.1",
    "sanitize-html": "^2.17.1",
    "think-cache": "^1.1.2",
    "think-cache-file": "^1.1.2",
    "think-logger3": "^1.4.0",
    "think-model": "^1.5.4",
    "think-model-mysql": "^1.1.7",
    "think-view": "^1.0.13",
    "think-view-nunjucks": "^1.0.11",
    "thinkjs": "4.0.0-alpha.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "think-inspect": "0.0.2"
  },
  "repository": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "log4js": "^6.9.1",
    "mysql": "^2.18.1",
    "fast-xml-parser": "^4.5.4",
    "validator": "^13.15.26",
    "xml2js": "^0.6.2",
    "form-data": "^2.5.4",
    "qs": "^6.14.1",
    "minimist": "^1.2.8"
  },
  "readmeFilename": "README.md"
}
