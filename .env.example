# Core runtime
NODE_ENV=development
PORT=8360

# JWT secrets
API_JWT_SECRET=change_me_api_secret
ADMIN_JWT_SECRET=change_me_admin_secret
# Compatibility aliases (optional)
API_TOKEN_SECRET=change_me_api_secret
ADMIN_TOKEN_SECRET=change_me_admin_secret

# Optional compatibility window for old tokens (comma-separated)
API_JWT_LEGACY_SECRETS=
ADMIN_JWT_LEGACY_SECRETS=

# JWT expiry policy
API_TOKEN_EXPIRES_IN=7d
ADMIN_TOKEN_EXPIRES_IN=12h

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=hiolabsDB

# WeChat pay (required for pay notify validation)
WEIXIN_APPID=wx-demo
WEIXIN_SECRET=wx-secret-demo
WEIXIN_MCH_ID=mch-demo
WEIXIN_PARTNER_KEY=partner-key-demo
WEIXIN_NOTIFY_URL=http://127.0.0.1:8360/api/pay/notify
WEIXIN_TEMPLATE_DELIVERY_ID=

# Express / logistics (optional, but required when using logistics APIs)
EXPRESS_APPID=
EXPRESS_APPKEY=
EXPRESS_REQUEST_URL=
MIANEXPRESS_APPID=
MIANEXPRESS_APPKEY=
MIANEXPRESS_REQUEST_URL=
MIANEXPRESS_PRINT_URL=
MIANEXPRESS_IP_SERVER_URL=
ALIEXPRESS_URL=
ALIEXPRESS_APPCODE=
ALIEXPRESS_SF_LAST_NO=

# Feature flags
ENABLE_TEST_PAY_ENDPOINT=false
FEATURE_PROMOTION_V1=true
VIP_ENABLED=true
VIP_DEFAULT_YEAR_PRICE=69
VIP_DEFAULT_QUARTER_PRICE=25
VIP_MONTHLY_COUPON_ID=0
VIP_MONTHLY_COUPON_COUNT=6
VIP_MONTHLY_COUPON_VALID_DAYS=30

# WeChat papay (phase 2 auto renew)
WEIXIN_PAPAY_SERVICE_ID=
WEIXIN_PAPAY_NOTIFY_URL=
WEIXIN_PAPAY_MCH_ID=
WEIXIN_PAPAY_API_V3_KEY=
WEIXIN_PAPAY_SERIAL_NO=
WEIXIN_PAPAY_PRIVATE_KEY_PATH=
WEIXIN_PAPAY_PLATFORM_CERT_PATH=

# Test runner defaults
COUPON_TEST_BASE_URL=http://127.0.0.1:8360
COUPON_TEST_DB_HOST=127.0.0.1
COUPON_TEST_DB_PORT=3306
COUPON_TEST_DB_USER=root
COUPON_TEST_DB_PASSWORD=root
COUPON_TEST_DB_NAME=hiolabsDB
COUPON_TEST_USER_ID=1048
COUPON_TEST_ADMIN_USER_ID=14

SECURITY_TEST_BASE_URL=http://127.0.0.1:8360
SECURITY_TEST_DB_HOST=127.0.0.1
SECURITY_TEST_DB_PORT=3306
SECURITY_TEST_DB_USER=root
SECURITY_TEST_DB_PASSWORD=root
SECURITY_TEST_DB_NAME=hiolabsDB
SECURITY_TEST_USER_A_ID=1048
SECURITY_TEST_USER_B_ID=2048

AUTH_CONTEXT_TEST_BASE_URL=http://127.0.0.1:8360
AUTH_CONTEXT_TEST_DB_HOST=127.0.0.1
AUTH_CONTEXT_TEST_DB_PORT=3306
AUTH_CONTEXT_TEST_DB_USER=root
AUTH_CONTEXT_TEST_DB_PASSWORD=root
AUTH_CONTEXT_TEST_DB_NAME=hiolabsDB
AUTH_CONTEXT_TEST_USER_A_ID=1048
AUTH_CONTEXT_TEST_USER_B_ID=2048
AUTH_CONTEXT_TEST_ROUNDS=20
